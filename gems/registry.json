      "id": "gem-notebooklm",
      "name": "NotebookLM Deepdive Audio Overviews",
      "status": "active",
      "description": "Fires during ready_bag or manual invocation to create a timestamped NotebookLM notebook, upload a new-evidence context brief as a source, and generate up to 5 themed deep-dive Audio Overviews (30–40 min each). Downloads resulting MP3s to AUDIO_OVERVIEW_LOCKER/.",
      "inputs": {
        "databases": [
          "data/evidence_hub.db"
        ],
        "templates": [
          "prompts/notebooklm_templates.json"
        ]
      },
      "outputs": {
        "directories": {
          "AUDIO_OVERVIEW_LOCKER": {
            "location": "data/AUDIO_OVERVIEW_LOCKER/",
            "structure": "YYYY-MM-DD_HH-MM/{audio files, briefs/, index.json}",
            "notes": "Each run creates a timestamped session folder. index.json tracks all sessions and notebook URLs."
          }
        },
        "files": [
          "data/AUDIO_OVERVIEW_LOCKER/briefings/{session}_{template}.md",
          "data/AUDIO_OVERVIEW_LOCKER/index.json"
        ]
      },
      "scripts": {
        "main": "scripts/notebooklm_deepdive.py",
        "templates": "prompts/notebooklm_templates.json",
        "skill": ".agent/skills/notebooklm/scripts/run.py"
      },
      "audio_templates": [
        {
          "id": "full-case-overview",
          "priority": 1,
          "description": "Master briefing — all claims, all players, full arc (~35 min)"
        },
        {
          "id": "new-evidence-spotlight",
          "priority": 2,
          "description": "War room review of new evidence added since last session (~20 min)"
        },
        {
          "id": "financial-crimes",
          "priority": 3,
          "description": "Forensic accounting deep dive — PPP, draws, QuickBooks, K-1 (~30 min)"
        },
        {
          "id": "sg-employment-timeline",
          "priority": 4,
          "description": "The fake employee scheme — W-2, double-dip, weaponization (~25 min)"
        },
        {
          "id": "agency-referral-brief",
          "priority": 5,
          "description": "FBI / IRS / SBA / State AG referral briefing by federal statute (~20 min)"
        }
      ],
      "trigger": {
        "manual": "python scripts/notebooklm_deepdive.py",
        "single_template": "python scripts/notebooklm_deepdive.py --template new-evidence-spotlight",
        "dry_run": "python scripts/notebooklm_deepdive.py --dry-run",
        "ready_bag_hook": "Called automatically at the end of save_ready_bag.py",
        "github_hook": "Called when new evidence is committed — see gems/notebooklm_hook.sh"
      },
      "usage": {
        "list_templates": "python scripts/notebooklm_deepdive.py --list-templates",
        "all_templates": "python scripts/notebooklm_deepdive.py",
        "recent_7_days": "python scripts/notebooklm_deepdive.py --days 7",
        "attach_url": "python scripts/notebooklm_deepdive.py --notebook-url https://notebooklm.google.com/notebook/..."
      },
