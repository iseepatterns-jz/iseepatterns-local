{
  "gems": [
    {
      "id": "gem-imessages",
      "name": "iMessage Forensic Repository",
      "status": "active",
      "description": "Historical iMessage archives from LG's backups and exports. Used to identify gaslighting patterns and timeline admissions.",
      "inputs": {
        "raw_files": [
          "data/chat_master.db",
          "data/jz_lg_imessage_logs_all_numbered.csv"
        ],
        "file_types": [".db", ".csv"]
      },
      "outputs": {
        "databases": {
          "chat_master.db": {
            "location": "data/chat_master.db",
            "tables": ["message", "handle", "chat"],
            "access": "read-only"
          }
        }
      },
      "scripts": {
        "ingest": [
          "ingest/imessage_ingest.py"
        ],
        "utility": [
          "scripts/consolidate_forensic_chats.py",
          "scripts/extract_imessage_admissions.py",
          "scripts/extract_gaslighting_patterns.py"
        ]
      },
      "canonical_id_format": "message_guid (e.g., p:0/... or UUID)",
      "evidence_source_type": "imessage",
      "dependencies": [],
      "api_routes": [
        "app/app/api/imessages/",
        "app/app/api/transcripts/"
      ],
      "ui_pages": [
        "app/app/transcripts/",
        "app/app/evidence-hub/"
      ],
      "db_accessor": "getImessageDb()"
    },
    {
      "id": "gem-gmail",
      "name": "Gmail Evidence Locker",
      "status": "active",
      "description": "Full Gmail account index for lucas@rowboatcreative.com, rowboatcreative@gmail.com, and rowboatcreativeaccounting@gmail.com. Contains 741k+ records.",
      "inputs": {
        "raw_files": [
          "data/MBOX_LOCKER/mbox_metadata.db",
          "data/ROWBOAT_CREATIVE_LOCKER/2024-06-22-all-metadata.csv"
        ],
        "file_types": [".db", ".csv", ".mbox"]
      },
      "outputs": {
        "databases": {
          "mbox_metadata.db": {
            "location": "data/MBOX_LOCKER/mbox_metadata.db",
            "tables": ["messages", "labels"],
            "access": "read-only"
          }
        }
      },
      "scripts": {
        "ingest": [
          "ingest/mbox_metadata_ingest.py",
          "scripts/update_mbox_labels.py"
        ],
        "utility": [
          "scripts/search_emails.py",
          "scripts/export_evidence_chain.py"
        ]
      },
      "canonical_id_format": "message_id (e.g., <...-google.com>)",
      "evidence_source_type": "email",
      "dependencies": [],
      "api_routes": [
        "app/app/api/emails/"
      ],
      "ui_pages": [
        "app/app/emails/"
      ],
      "db_accessor": "getCommDb()"
    },
    {
      "id": "gem-financial-txns",
      "name": "Financial Transactions",
      "status": "active",
      "description": "Normalizes RBC statements, Printavo orders, Amazon purchases, and QuickBooks data into a unified transactions table. Significant events (>$5k) promoted to Evidence Hub.",
      "inputs": {
        "raw_files": [
          "data/FINANCIAL_LOCKER/",
          "data/STATEMENTS_LOCKER/",
          "data/AMAZON_LOCKER/",
          "data/DRAWS_LOCKER/",
          "data/OWNER_CASH_INFUSION_LOCKER/"
        ],
        "file_types": [".csv", ".xlsx", ".pdf"]
      },
      "outputs": {
        "databases": {
          "workbench.db": {
            "location": "app/workbench.db (auto-created)",
            "tables": ["accounts", "transactions"],
            "schema": "schemas/financials.sql",
            "access": "read-write"
          }
        }
      },
      "scripts": {
        "ingest": [
          "ingest/financial_ingest.py",
          "ingest/financial_to_evidence_hub.py"
        ],
        "utility": [
          "scripts/ingest_financial_truth.py",
          "scripts/financial_discrepancy_matcher.py",
          "scripts/ingest_amazon_to_evidence_hub.py",
          "scripts/ingest_flights_to_evidence_hub.py",
          "analyze_draws.py"
        ]
      },
      "schemas": ["schemas/financials.sql"],
      "canonical_id_format": "txn_{source}_{id} (e.g., txn_RBC_2020-05-26-001)",
      "evidence_source_type": "financial",
      "dependencies": [],
      "api_routes": [
        "app/app/api/financials/",
        "app/app/api/financials/import",
        "app/app/api/financials/transactions",
        "app/app/api/financials/automatch",
        "app/app/api/financials/finalize-verification"
      ],
      "ui_pages": [
        "app/app/financials/",
        "app/app/financials/import",
        "app/app/financials/review/[id]"
      ],
      "db_accessor": "getWorkbenchDb()"
    },
    {
      "id": "gem-tax-returns",
      "name": "Tax Returns & K-1s",
      "status": "active",
      "description": "Ingests 1120-S corporate tax returns and Schedule K-1 partner distributions, links to ledger entries and email correspondence.",
      "inputs": {
        "raw_files": [
          "data/TAXES_LOCKER/"
        ],
        "file_types": [".pdf"]
      },
      "outputs": {
        "databases": {
          "workbench.db": {
            "location": "app/workbench.db",
            "tables": ["tax_returns", "tax_k1_details"],
            "schema": "schemas/tax_returns.sql",
            "access": "read-write"
          }
        }
      },
      "scripts": {
        "ingest": [
          "ingest/tax_ingest.py",
          "ingest/tax_to_evidence_hub.py",
          "ingest/link_tax_to_ledger.py",
          "ingest/link_taxes_to_emails.py"
        ]
      },
      "schemas": ["schemas/tax_returns.sql"],
      "canonical_id_format": "tax_{year}_{entity}_{id}",
      "evidence_source_type": "tax",
      "dependencies": ["gem-financial-txns", "gem-gmail"],
      "api_routes": [
        "app/app/api/taxes/"
      ],
      "ui_pages": [
        "app/app/taxes/"
      ],
      "db_accessor": "getWorkbenchDb()"
    },
    {
      "id": "gem-evidence-hub",
      "name": "The Hub (Evidence Dashboard)",
      "status": "active",
      "description": "The unified interface for cross-source evidence correlation. Links emails, messages, and transactions by canonical_id.",
      "inputs": {
        "raw_files": ["data/evidence_hub.db"],
        "file_types": [".db"]
      },
      "outputs": {
        "databases": {
          "evidence_hub.db": {
            "location": "data/evidence_hub.db",
            "tables": ["nexus", "evidence_source", "provenance"],
            "access": "read-only"
          }
        }
      },
      "scripts": {
        "utility": [
          "scripts/rebuild_hub_index.py",
          "scripts/check_hub_provenance.py"
        ]
      },
      "canonical_id_format": "nexus_uuid",
      "evidence_source_type": "meta",
      "dependencies": ["gem-imessages", "gem-gmail", "gem-financial-txns"],
      "api_routes": [
        "app/app/api/evidence-hub/"
      ],
      "ui_pages": [
        "app/app/evidence-hub/",
        "app/app/dashboard/"
      ],
      "db_accessor": "getEvidenceHubDb()"
    }
  ],
  "registry_version": "1.4.0",
  "project_id": "lawmodel1-RC-2026",
  "client_id": "rowboat-creative",
  "data_root_structure": {
    "data_locker": "data/",
    "artifact_outputs": "exports/",
    "governance_docs": "docs/",
    "central_db": "app/workbench.db"
  }
}
