{
  "name": "LawModel1 Evidence Pipeline Registry",
  "version": "1.1.0",
  "last_updated": "2026-03-15",
  "description": "Canonical registry of all forensic evidence ingestion gems, modular processing modules, and their output databases.",
  "gems": [
    {
      "id": "gem-email-mbox",
      "name": "Gmail MBOX Indexer",
      "description": "Ingests Gmail MBOX zip exports into a searchable, indexed email database with full-text search, label classification, and body extraction.",
      "inputs": {
        "raw_files": [
          "data/MBOX_LOCKER/2024-06-22_GMAIL_MBOX_ALL_LOCKER/2024-06-22_GMAIL_ALL_MBOX_ZIPPED/"
        ],
        "metadata_csv": "data/MBOX_LOCKER/2024-06-22_GMAIL_MBOX_ALL_LOCKER/2024-06-22_GMAIL_ALL_MBOX_ZIPPED/2024-06-22-all-metadata.csv",
        "file_types": [".zip", ".mbox", ".csv"]
      },
      "outputs": {
        "databases": {
          "gmail_master_index.db": {
            "location": "data/MBOX_LOCKER/2024-06-22_GMAIL_MBOX_ALL_LOCKER/2024-06-22_GMAIL_ALL_MBOX_ZIPPED/gmail_master_index.db",
            "tables": ["emails", "drive_links", "emails_fts"],
            "schema": "schemas/mbox_metadata.sql",
            "access": "read-write",
            "notes": "Primary master index for all queries; 741k records."
          }
        },
        "filtered_databases": [
          "data/MBOX_LOCKER/unused/accounting_all.db",
          "data/MBOX_LOCKER/unused/emails_LG_SM_SH_JZ.db"
        ]
      },
      "scripts": {
        "ingest": "ingest/mbox_metadata_ingest.py",
        "utilities": [
          "scripts/index_mbox_master.py",
          "scripts/recover_indexing.py"
        ]
      },
      "api_routes": ["/api/communications", "/api/search", "/api/coc"],
      "ui_pages": ["/communications", "/search", "/coc"]
    },
    {
      "id": "gem-imessage-chatdb",
      "name": "iMessage Forensic Decoder",
      "description": "Decodes Apple iMessage chat.db databases, extracts message history, handles multi-part messages, and decodes binary blobs.",
      "inputs": {
        "raw_files": ["chatdb_storage/"],
        "file_types": [".db"]
      },
      "outputs": {
        "databases": {
          "chat_master.db": {
            "location": "data/chat_master.db",
            "tables": ["messages", "handles", "chats"],
            "schema": "schemas/imessage_schema.sql",
            "access": "read-only"
          }
        }
      },
      "scripts": {
        "ingest": "ingest/imessage_ingest.py",
        "utilities": ["scripts/consolidate_forensic_chats.py"]
      },
      "api_routes": ["/api/imessages"],
      "ui_pages": ["/imessages"]
    },
    {
      "id": "gem-financial-txns",
      "name": "Financial Transaction Normalizer",
      "description": "Ingests and normalizes financial data from RBC statements (Excel), Printavo (CSV), and QuickBooks (EML/CSV) into a unified ledger.",
      "inputs": {
        "raw_files": ["data/FINANCIAL_LOCKER/"],
        "file_types": [".xlsx", ".csv", ".eml"]
      },
      "outputs": {
        "databases": {
          "workbench.db": {
            "tables": ["transactions", "accounts"],
            "schema": "schemas/financials.sql",
            "access": "read-write"
          }
        }
      },
      "scripts": {
        "ingest": "ingest/financial_ingest.py",
        "utilities": ["scripts/ingest_financial_truth.py"]
      },
      "api_routes": ["/api/financials"],
      "ui_pages": ["/financials"]
    },
    {
      "id": "gem-tax-returns",
      "name": "Tax Return Extractor",
      "description": "Extracts structured data from 1120-S tax returns and K-1 partner schedules to identify owner distributions and capital accounts.",
      "inputs": {
        "raw_files": ["data/TAXES_LOCKER/"],
        "file_types": [".pdf", ".xlsx"]
      },
      "outputs": {
        "databases": {
          "workbench.db": {
            "tables": ["tax_returns", "tax_k1_details"],
            "schema": "schemas/tax_returns.sql",
            "access": "read-write"
          }
        }
      },
      "dependencies": ["gem-financial-txns"],
      "scripts": {
        "ingest": "ingest/financial_ingest.py"
      }
    },
    {
      "id": "gem-players",
      "name": "Player Profile Generator",
      "description": "Builds unified person intelligence profiles from LinkedIn exports, email signatures, and iMessage contacts.",
      "inputs": {
        "raw_files": ["data/LINKED_IN_PROFILE_LOCKER/", "data/players.db"],
        "file_types": [".pdf", ".db"]
      },
      "outputs": {
        "databases": {
          "players.db": {
            "location": "data/players.db",
            "tables": ["players", "player_files"],
            "schema": "schemas/players.sql",
            "access": "read-only"
          }
        }
      },
      "scripts": {
        "ingest": "ingest/linkedin_ingest.py"
      },
      "api_routes": ["/api/players"],
      "ui_pages": ["/players"]
    },
    {
      "id": "gem-legal-docs",
      "name": "Court Document OCR & Embedder",
      "description": "Processes court filings, orders, and receiver reports using OCR and vector embedding for RAG-based legal analysis.",
      "inputs": {
        "raw_files": ["data/COURT_LOCKER/"],
        "file_types": [".pdf"]
      },
      "outputs": {
        "vector_store": "chroma_db/",
        "databases": {
          "workbench.db": {
            "tables": ["exhibit_sections"],
            "schema": "schemas/missing_schemas.sql"
          }
        }
      },
      "api_routes": ["/api/legal"],
      "ui_pages": ["/legal"]
    },
    {
      "id": "gem-transcripts",
      "name": "Transcript Processor",
      "description": "Transcribes and analyzes audio/video recordings from meetings and phone calls.",
      "inputs": {
        "raw_files": ["data/TRANSCRIPTS_LOCKER/"],
        "file_types": [".mp3", ".mp4", ".wav", ".vtt"]
      },
      "outputs": {
        "databases": {
          "workbench.db": {
            "tables": ["transcript_annotations"],
            "schema": "schemas/transcript_annotations.sql"
          }
        }
      },
      "api_routes": ["/api/transcripts"],
      "ui_pages": ["/transcripts"]
    },
    {
      "id": "gem-evidence-cards",
      "name": "Evidence Card Generator",
      "description": "The 'Master Hub' gem. Consolidates email, iMessage, and financial evidence into unified 'Evidence Cards' in the Evidence Hub.",
      "inputs": {
        "sources": ["gem-email-mbox", "gem-imessage-chatdb", "gem-financial-txns", "gem-players"]
      },
      "outputs": {
        "databases": {
          "evidence_hub.db": {
            "location": "data/evidence_hub.db",
            "tables": ["evidence", "evidence_origins", "participants", "entities", "evidence_participants"],
            "schema": "schemas/evidence_hub.sql",
            "access": "read-only"
          }
        }
      },
      "scripts": {
        "ingest": "ingest/refined_cards_ingest.py",
        "utilities": ["scripts/ingest_refined_cards.py", "scripts/verify_evidence_hub.py"]
      },
      "api_routes": ["/api/evidence-hub", "/api/entities"],
      "ui_pages": ["/evidence-hub", "/entities"]
    },
    {
      "id": "gem-rag-search",
      "name": "Forensic RAG Engine",
      "description": "Combines BM25 keyword search and vector similarity search across all evidence to provide grounded AI analysis.",
      "inputs": {
        "sources": ["gem-evidence-cards", "gem-legal-docs"],
        "vector_db": "chroma_db/",
        "keyword_index": "bm25_index.pkl"
      },
      "api_routes": ["/api/ai", "/api/briefing"],
      "ui_pages": ["/briefing"]
    },
    {
      "id": "gem-chain-of-custody",
      "name": "Chain of Custody Auditor",
      "description": "Maintains the evidentiary audit trail, ensuring every record traces back to a raw source file and all modifications are logged.",
      "inputs": {
        "sources": ["gem-email-mbox", "gem-imessage-chatdb", "gem-financial-txns"]
      },
      "outputs": {
        "databases": {
          "workbench.db": {
            "tables": ["coc_notes_audit", "workbench_audit"],
            "schema": "schemas/workbench.sql"
          }
        }
      },
      "scripts": {
        "utilities": ["scripts/update_chain_of_custody.py"]
      },
      "api_routes": ["/api/coc"],
      "ui_pages": ["/coc"]
    }
  ]
}
